# PostgreSQL connection string (Neon: https://neon.tech — free tier)
# Neon dashboard → Connection Details → "Pooled connection"
DATABASE_URL="postgresql://user:password@ep-example-123456.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# football-data.org API key (free tier): https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=""

# football-data.org numeric team ID for GD Estoril Praia.
# Look it up via GET https://api.football-data.org/v4/competitions/PPL/teams
FOOTBALL_DATA_ESTORIL_TEAM_ID="582"

# football-data.org competition code for Liga Portugal (Primeira Liga)
FOOTBALL_DATA_COMPETITION_CODE="PPL"

# Optional: secret used to authorize calls to /api/cron/sync.
# Vercel Cron Jobs send it automatically as "Authorization: Bearer <CRON_SECRET>"
# when this env var is set on the project. Leave empty to disable the check locally.
CRON_SECRET=""
